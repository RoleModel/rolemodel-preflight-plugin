{
  "name": "rolemodel-preflight-plugin",
  "version": "1.0.0",
  "private": true,
  "description": "RoleModel preflight plugin for Framer",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "publish:plugin": "bash scripts/publish.sh"
  },
  "dependencies": {
    "@framer/plugin": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.21.3",
    "husky": "^9.1.7",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^5.5.4",
    "ultracite": "7.9.3",
    "vite": "^5.4.2",
    "vite-plugin-mkcert": "1.17.8"
  }
}
